# ─────────────────────────────────────────────────────────────
# Supabase — copy to .env.local and fill in your project values.
# The app runs with rich SAMPLE DATA even if these are left blank,
# so you can preview the full experience before wiring up Supabase.
# ─────────────────────────────────────────────────────────────

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Used by the admin dashboard for privileged writes.
# NEVER expose this in client code or commit it.
SUPABASE_SERVICE_ROLE_KEY=
