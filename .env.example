# ─────────────────────────────────────────────────────────────
# Copy to .env.local (local) or set in Vercel → Project → Settings →
# Environment Variables (production).
#
# The public site runs on rich SAMPLE DATA even with all of these blank,
# so you can preview the experience before wiring up the backend.
# ─────────────────────────────────────────────────────────────

# ── Supabase ──────────────────────────────────────────────────
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Bypasses RLS — used by checkout & webhook to create/fulfil
# orders. NEVER expose to the client or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# ── Flutterwave ───────────────────────────────────────────────
# Flutterwave dashboard → Settings → API Keys. Use TEST keys first.
FLW_SECRET_KEY=
NEXT_PUBLIC_FLW_PUBLIC_KEY=
# Settings → Webhooks → "Secret hash" (choose any strong string, put the
# same value here and in the dashboard). Used to verify webhook calls.
FLW_WEBHOOK_HASH=

# ── App ───────────────────────────────────────────────────────
# Public base URL, used to build Flutterwave redirect links.
# Local: http://localhost:3000 · Prod: https://your-domain.com
# (If unset, the server falls back to the incoming request's origin.)
NEXT_PUBLIC_BASE_URL=
